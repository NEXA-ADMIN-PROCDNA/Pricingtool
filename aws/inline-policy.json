{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SSMReadNexaDev",
      "Effect": "Allow",
      "Action": ["ssm:GetParameters", "ssm:GetParameter"],
      "Resource": "arn:aws:ssm:us-east-1:492237925351:parameter/nexa/dev/*"
    },
    {
      "Sid": "KMSDecryptViaSSM",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "*",
      "Condition": { "StringEquals": { "kms:ViaService": "ssm.us-east-1.amazonaws.com" } }
    },
    {
      "Sid": "Logs",
      "Effect": "Allow",
      "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
      "Resource": "arn:aws:logs:us-east-1:492237925351:log-group:/ecs/nexa-dev*"
    },
    {
      "Sid": "S3NexaDev",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::nexa-dev-bucket",
        "arn:aws:s3:::nexa-dev-bucket/*"
      ]
    }
  ]
}
